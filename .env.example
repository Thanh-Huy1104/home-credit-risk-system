# Environment Configuration
# Copy this file to .env and fill in your values

# Project settings
PROJECT_NAME=home-credit-risk
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database
DUCKDB_PATH=data/duckdb/home_credit.duckdb

# Model settings
MODEL_VERSION=v1.0.0
MODEL_ARTIFACTS_DIR=models/artifacts

# API settings (for serving)
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Feature flags
ENABLE_SHAP_EXPLANATIONS=true
ENABLE_PREDICTION_LOGGING=true
